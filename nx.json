{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "analytics": false,
  "nxCloudId": "69fbeb386cca26cc90ec5c5e",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s"
    ],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/*.yml"],
    "envRuntime": [
      {
        "env": "IMAGE_TAG"
      },
      {
        "env": "BUILD_NUMBER"
      },
      {
        "env": "DOCKER_PLATFORMS"
      },
      {
        "env": "REGISTRY"
      },
      {
        "env": "ORG_LC"
      },
      {
        "env": "COMMIT_SHA"
      },
      {
        "env": "BUILD_DATE"
      },
      {
        "env": "REPO_URL"
      },
      {
        "env": "VERSION"
      },
      {
        "env": "LICENCE"
      }
    ],
    "runtimeEnv": [
      {
        "env": "NODE_ENV"
      },
      {
        "env": "CI"
      }
    ]
  },
  "plugins": [
    {
      "plugin": "@nx/next/plugin",
      "options": {
        "startTargetName": "start",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "serveStaticTargetName": "serve-static",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps"
      }
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e",
        "ciTargetName": "e2e-ci"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/jest/plugin",
      "options": {
        "targetName": "test"
      },
      "exclude": ["apps/central-hub/central-hub-api-e2e/**/*", "apps/vendor-portal/vendor-api-server-e2e/**/*", "apps/customer-portal/customer-portal-api-e2e/**/*"]
    },
    {
      "plugin": "@nx/webpack/plugin",
      "options": {
        "buildTargetName": "build",
        "serveTargetName": "serve",
        "previewTargetName": "preview",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps",
        "serveStaticTargetName": "serve-static"
      }
    },
    {
      "plugin": "@nx/docker",
      "options": {
        "buildTarget": {
          "name": "docker:build",
          "skipDefaultTag": true,
          "cwd": ".",
          "env": {
            "PROJECT_NAME": "{projectName}"
          },
          "args": [
            "--file",
            "{projectRoot}/Dockerfile",
            "--platform",
            "${DOCKER_PLATFORMS:-linux/amd64}",
            "--tag",
            "${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:${IMAGE_TAG:?IMAGE_TAG must be set}",
            "--tag",
            "${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:${BUILD_NUMBER:-0}",
            "--label",
            "org.opencontainers.image.revision=${COMMIT_SHA:-unknown}",
            "--label",
            "org.opencontainers.image.created=${BUILD_DATE:-unknown}",
            "--label",
            "org.opencontainers.image.title=${PROJECT_NAME##*/}",
            "--label",
            "org.opencontainers.image.source=${REPO_URL:-unknown}",
            "--label",
            "org.opencontainers.image.version=${VERSION:-0.0.0}",
            "--label",
            "org.opencontainers.image.licenses=${LICENCE:-MIT}",
            "--cache-from",
            "type=registry,ref=${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:cache"
          ]
        },
        "runTarget": {
          "name": "docker:run",
          "args": ["--rm", "--publish", "3000:3000", "--env", "NODE_ENV=production"]
        },
        "nx-release-publish": {
          "imageTag": "${IMAGE_TAG:-$VERSION}"
        }
      }
    }
  ],
  "pluginsConfig": {
    "@nx/js": {
      "projectsAffectedByDependencyUpdates": "auto"
    }
  },
  "generators": {
    "@nx/next": {
      "application": {
        "style": "tailwind",
        "linter": "eslint"
      }
    },
    "@nx/react": {
      "library": {
        "unitTestRunner": "jest"
      }
    }
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"]
    },
    "typecheck": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"],
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit"
      }
    },
    "quality": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"]
    },
    "@nx/next:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production", "sharedGlobals"],
      "outputs": ["{options.outputPath}"]
    },
    "deploy-metadata": {
      "cache": false,
      "inputs": ["default", "sharedGlobals"],
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"]
    },
    "docker:metadata": {
      "cache": true,
      "dependsOn": ["nx-release-publish"],
      "inputs": ["production", "sharedGlobals", "{workspaceRoot}/tools/containers/write-image-manifest.mjs"],
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}/image.json"]
    },
    "nx-release-publish": {
      "cache": false,
      "dependsOn": ["docker:build"],
      "inputs": ["production", "sharedGlobals", "envRuntime"]
    },
    "prune-lockfile": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["production", "^production", "{workspaceRoot}/pnpm-lock.yaml"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/package.json", "{workspaceRoot}/dist/{projectRoot}/pnpm-lock.yaml"]
    },
    "copy-workspace-modules": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["production", "^production", "{workspaceRoot}/pnpm-lock.yaml"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}/workspace_modules"]
    },
    "package": {
      "cache": true,
      "dependsOn": ["build"],
      "inputs": ["production", "^production"]
    },
    "container:image-metadata": {
      "cache": true,
      "inputs": ["production", "sharedGlobals", "{workspaceRoot}/scripts/container-image-metadata.mjs"],
      "outputs": ["{workspaceRoot}/dist/container-image-metadata.json"]
    },
    "local-registry": {
      "cache": false,
      "inputs": ["default", "{workspaceRoot}/.verdaccio/config.yml"],
      "outputs": ["{workspaceRoot}/tmp/local-registry"]
    },
    "docker:build": {
      "cache": false,
      "dependsOn": ["build", "prune"],
      "inputs": ["production", "^production", "sharedGlobals", "envRuntime", "{projectRoot}/Dockerfile"]
    },
    "docker:run": {
      "cache": false,
      "dependsOn": ["docker:build"],
      "inputs": ["production", "sharedGlobals", "runtimeEnv"]
    }
  },
  "release": {
    "groups": {
      "ethio-connect-packages": {
        "projects": ["@ethio-connect-et/ethioconnect"],
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        },
        "releaseTag": {
          "pattern": "v{version}",
          "checkAllBranchesWhen": ["development", "testing", "staging"],
          "strictPreid": true
        }
      },
      "ethio-connect-backend-services": {
        "projects": ["@ethio-connect/central-hub-api", "@ethio-connect/customer-portal-api", "@ethio-connect/vendor-api-server"],
        "docker": true,
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        },
        "releaseTag": {
          "pattern": "v{version}",
          "checkAllBranchesWhen": ["development", "testing", "staging"],
          "strictPreid": true
        }
      },
      "ethio-connect-dashboards-frontends": {
        "projects": ["@ethio-connect/central-hub-dashboard", "@ethio-connect/customer-portal-dashboard", "@ethio-connect/vendor-portal-dashboard"],
        "docker": true,
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        },
        "releaseTag": {
          "pattern": "v{version}",
          "checkAllBranchesWhen": ["development", "testing", "staging"],
          "strictPreid": true
        }
      },
      "ethio-connect-public-websites": {
        "projects": ["@ethio-connect/public-website"],
        "docker": true,
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        },
        "releaseTag": {
          "pattern": "v{version}",
          "checkAllBranchesWhen": ["development", "testing", "staging"],
          "strictPreid": true
        }
      }
    }
  }
}
