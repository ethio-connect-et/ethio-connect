{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "nxCloudId": "69f299b3bd50ccb2dc8f1fc7",
  "analytics": false,
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s"
    ],
    "sharedGlobals": ["{workspaceRoot}/.github/workflows/*.yml"]
  },
  "plugins": [
    {
      "plugin": "@nx/next/plugin",
      "options": {
        "startTargetName": "start",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "serveStaticTargetName": "serve-static",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps"
      }
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e",
        "ciTargetName": "e2e-ci"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/jest/plugin",
      "options": {
        "targetName": "test"
      },
      "exclude": [
        "apps/central-hub/central-hub-api-e2e/**/*",
        "apps/vendor-portal/vendor-api-server-e2e/**/*",
        "apps/customer-portal/customer-portal-api-e2e/**/*"
      ]
    },
    {
      "plugin": "@nx/webpack/plugin",
      "options": {
        "buildTargetName": "build",
        "serveTargetName": "serve",
        "previewTargetName": "preview",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps",
        "serveStaticTargetName": "serve-static"
      }
    },
    {
      "plugin": "@nx/docker",
      "options": {
        "buildTarget": {
          "name": "docker:build",
          "skipDefaultTag": true,
          "cwd": ".",
          "env": {
            "PROJECT_NAME": "{projectName}"
          },
          "args": [
            "--file",
            "{projectRoot}/Dockerfile",
            "--platform",
            "${DOCKER_PLATFORMS:-linux/amd64}",
            "--tag",
            "${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:${IMAGE_TAG:?IMAGE_TAG must be set}",
            "--tag",
            "${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:${BUILD_NUMBER:-0}",
            "--label",
            "org.opencontainers.image.revision=${COMMIT_SHA:-unknown}",
            "--label",
            "org.opencontainers.image.created=${BUILD_DATE:-unknown}",
            "--label",
            "org.opencontainers.image.title=${PROJECT_NAME##*/}",
            "--label",
            "org.opencontainers.image.source=${REPO_URL:-unknown}",
            "--label",
            "org.opencontainers.image.version=${VERSION:-0.0.0}",
            "--label",
            "org.opencontainers.image.licenses=${LICENCE:-MIT}",
            "--cache-from",
            "type=registry,ref=${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:cache",
            "--push"
          ]
        },
        "runTarget": {
          "name": "docker:run",
          "args": [
            "--rm",
            "--publish",
            "3000:3000",
            "--env",
            "NODE_ENV=production"
          ]
        },
        "nx-release-publish": {
          "imageTag": "${IMAGE_TAG:-$VERSION}"
        }
      }
    }
  ],
  "pluginsConfig": {
    "@nx/js": {
      "projectsAffectedByDependencyUpdates": "auto"
    }
  },
  "generators": {
    "@nx/next": {
      "application": {
        "style": "tailwind",
        "linter": "eslint"
      }
    },
    "@nx/react": {
      "library": {
        "unitTestRunner": "jest"
      }
    }
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "docker:build": {
      "cache": false,
      "dependsOn": ["build", "prune"],
      "inputs": [
        "production",
        "^production",
        "sharedGlobals",
        "{projectRoot}/Dockerfile"
      ]
    },
    "nx-release-publish": {
      "cache": false,
      "options": {
        "quiet": false
      }
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"]
    },
    "typecheck": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"],
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit"
      }
    },
    "quality": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"]
    },
    "format:write": {
      "cache": false,
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\""
      }
    },
    "format:check": {
      "cache": true,
      "inputs": ["default", "^production", "sharedGlobals"],
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,scss}\""
      }
    },
    "@nx/next:build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["default", "^production", "sharedGlobals"],
      "outputs": ["{options.outputPath}"]
    }
  },
  "release": {
    "groups": {
      "ethio-connect-packages": {
        "projects": ["@ethio-connect-et/ethioconnect"],
        "releaseTagPattern": "v{version}",
        "releaseTagPatternStrictPreid": true,
        "projectsRelationship": "independent",
        "version": {
          "conventionalCommits": true
        },
        "changelog": {
          "projectChangelogs": true,
          "workspaceChangelog": false
        },
        "releaseTagPatternCheckAllBranchesWhen": [
          "development",
          "testing",
          "staging"
        ],
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        }
      },
      "ethio-connect-backend-services": {
        "projects": [
          "@ethio-connect/central-hub-api",
          "@ethio-connect/customer-portal-api",
          "@ethio-connect/vendor-api-server"
        ],
        "releaseTagPattern": "v{version}",
        "releaseTagPatternStrictPreid": true,
        "docker": true,
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "releaseTagPatternCheckAllBranchesWhen": [
          "development",
          "testing",
          "staging"
        ],
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        }
      },
      "ethio-connect-dashboards-frontends": {
        "projects": [
          "@ethio-connect/central-hub-dashboard",
          "@ethio-connect/customer-portal-dashboard",
          "@ethio-connect/vendor-portal-dashboard"
        ],
        "releaseTagPattern": "v{version}",
        "releaseTagPatternStrictPreid": true,
        "docker": true,
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "releaseTagPatternCheckAllBranchesWhen": [
          "development",
          "testing",
          "staging"
        ],
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        }
      },
      "ethio-connect-public-websites": {
        "projects": ["@ethio-connect/public-website"],
        "releaseTagPattern": "v{version}",
        "releaseTagPatternStrictPreid": true,
        "docker": true,
        "projectsRelationship": "independent",
        "version": {
          "specifierSource": "conventional-commits",
          "currentVersionResolver": "git-tag",
          "fallbackCurrentVersionResolver": "disk",
          "updateDependents": "auto"
        },
        "changelog": {
          "workspaceChangelog": {
            "createRelease": "github"
          },
          "projectChangelogs": true,
          "git": {
            "commit": true,
            "tag": true
          }
        },
        "releaseTagPatternCheckAllBranchesWhen": [
          "development",
          "testing",
          "staging"
        ],
        "versionPlans": {
          "ignorePatternsForPlanCheck": ["**/*.md", "**/.github/**", "docs/**"]
        }
      }
    }
  }
}
