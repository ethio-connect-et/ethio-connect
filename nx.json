{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "analytics": false,
  "nxCloudId": "69f299b3bd50ccb2dc8f1fc7",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [
      "{workspaceRoot}/nx.json",
      "{workspaceRoot}/package.json",
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/tsconfig.base.json",
      "{workspaceRoot}/eslint.config.mjs",
      "{workspaceRoot}/jest.preset.js",
      "{workspaceRoot}/.github/workflows/*.yml"
    ],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/jest.config.[jt]s",
      "!{projectRoot}/src/test-setup.[jt]s",
      "!{projectRoot}/test-setup.[jt]s",
      "!{projectRoot}/playwright.config.[jt]s",
      "!{projectRoot}/**/*.stories.@(ts|tsx|js|jsx|mdx)"
    ],
    "ci": ["default", "production"],
    "e2e": ["default", "production", "{workspaceRoot}/playwright.config.*"]
  },
  "plugins": [
    {
      "plugin": "@nx/next/plugin",
      "options": {
        "startTargetName": "start",
        "buildTargetName": "build",
        "devTargetName": "dev",
        "serveStaticTargetName": "serve-static",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps"
      }
    },
    {
      "plugin": "@nx/playwright/plugin",
      "options": {
        "targetName": "e2e"
      }
    },
    {
      "plugin": "@nx/eslint/plugin",
      "options": {
        "targetName": "lint"
      }
    },
    {
      "plugin": "@nx/jest/plugin",
      "options": {
        "targetName": "test"
      },
      "exclude": [
        "apps/central-hub/central-hub-api-e2e/**/*",
        "apps/vendor-portal/vendor-api-server-e2e/**/*",
        "apps/customer-portal/customer-portal-api-e2e/**/*"
      ]
    },
    {
      "plugin": "@nx/webpack/plugin",
      "options": {
        "buildTargetName": "build",
        "serveTargetName": "serve",
        "previewTargetName": "preview",
        "buildDepsTargetName": "build-deps",
        "watchDepsTargetName": "watch-deps",
        "serveStaticTargetName": "serve-static"
      }
    },
    {
      "plugin": "@nx/docker",
      "options": {
        "buildTarget": {
          "name": "docker:build",
          "skipDefaultTag": true,
          "cwd": ".",
          "env": {
            "PROJECT_NAME": "{projectName}"
          },
          "args": [
            "--file",
            "{projectRoot}/Dockerfile",
            "--tag",
            "${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:${IMAGE_TAG:-latest}",
            "--tag",
            "${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:${BUILD_NUMBER:-0}",
            "--label",
            "org.opencontainers.image.revision=${COMMIT_SHA:-unknown}",
            "--label",
            "org.opencontainers.image.created=${BUILD_DATE:-unknown}",
            "--label",
            "org.opencontainers.image.title=${PROJECT_NAME##*/}",
            "--label",
            "org.opencontainers.image.source=${REPO_URL:-unknown}",
            "--label",
            "org.opencontainers.image.version=${VERSION:-0.0.1}",
            "--label",
            "org.opencontainers.image.licenses=${LICENCE:-MIT}",
            "--cache-from",
            "type=registry,ref=${REGISTRY:-ghcr.io}/${ORG_LC:-ethio-connect-et}/${PROJECT_NAME##*/}:cache"
          ]
        },
        "runTarget": {
          "name": "docker:run"
        }
      }
    }
  ],
  "generators": {
    "@nx/next": {
      "application": {
        "style": "tailwind",
        "linter": "eslint"
      }
    },
    "@nx/react": {
      "library": {
        "unitTestRunner": "jest"
      }
    }
  },
  "targetDefaults": {
    "@nx/js:tsc": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": ["{options.outputPath}"]
    },
    "@nx/eslint:lint": {
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": ["{options.outputFile}"]
    },
    "@nx/jest:jest": {
      "cache": true,
      "inputs": ["ci", "^production"],
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "passWithNoTests": true
      }
    },
    "@nx/playwright:playwright": {
      "cache": true,
      "inputs": ["e2e", "^production"],
      "outputs": [
        "{workspaceRoot}/dist/.playwright/{projectRoot}",
        "{workspaceRoot}/playwright-report/{projectRoot}"
      ]
    },
    "build": {
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": [
        "{workspaceRoot}/dist/{projectRoot}",
        "{projectRoot}/dist",
        "{projectRoot}/build",
        "{projectRoot}/.next"
      ]
    },
    "test": {
      "cache": true,
      "inputs": ["ci", "^production"],
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}",
        "{projectRoot}/test-results"
      ]
    },
    "lint": {
      "cache": true,
      "inputs": ["default", "^default"],
      "outputs": ["{options.outputFile}"]
    },
    "e2e": {
      "cache": true,
      "inputs": ["e2e", "^production"],
      "outputs": [
        "{workspaceRoot}/dist/.playwright/{projectRoot}",
        "{workspaceRoot}/playwright-report/{projectRoot}",
        "{projectRoot}/test-results"
      ]
    },
    "package": {
      "cache": true,
      "inputs": ["production", "^production"],
      "outputs": ["{workspaceRoot}/dist/{projectRoot}", "{projectRoot}/dist"]
    },
    "container": {
      "cache": true,
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/Dockerfile",
        "{projectRoot}/Dockerfile"
      ],
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}"]
    },
    "docker": {
      "cache": true,
      "inputs": [
        "production",
        "^production",
        "{workspaceRoot}/Dockerfile",
        "{projectRoot}/Dockerfile"
      ],
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}"]
    }
  },
  "release": {
    "version": {
      "conventionalCommits": true,
      "preVersionCommand": "pnpm nx run-many -t build --projects=@ethio-connect/api-common,@ethio-connect/api-features,@ethio-connect/frontend-features,@ethio-connect/ui-components,@ethio-connect/ethioconnect"
    },
    "projectsRelationship": "independent",
    "groups": {
      "shared-libs": {
        "docker": false,
        "projects": [
          "@ethio-connect/api-common",
          "@ethio-connect/api-features",
          "@ethio-connect/frontend-features",
          "@ethio-connect/ui-components",
          "@ethio-connect/ethioconnect"
        ]
      },
      "central-hub": {
        "docker": true,
        "projects": [
          "@ethio-connect/central-hub-api",
          "@ethio-connect/central-hub-dashboard",
          "@ethio-connect/central-hub-public-dashboard"
        ]
      },
      "customer-portal": {
        "docker": true,
        "projects": [
          "@ethio-connect/customer-portal-api",
          "@ethio-connect/customer-portal-dashboard"
        ]
      },
      "vendor-portal": {
        "docker": true,
        "projects": [
          "@ethio-connect/vendor-api-server",
          "@ethio-connect/vendor-portal-dashboard"
        ]
      }
    },
    "git": {
      "commit": true,
      "tag": true,
      "conventionalCommits": true
    },
    "changelog": {
      "workspaceChangelog": {
        "createRelease": "github"
      },
      "projectChangelogs": true
    }
  }
}
