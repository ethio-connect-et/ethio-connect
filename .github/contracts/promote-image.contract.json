{
  "contract_version": "1.0",
  "registry_prefix": "ghcr.io/ethio-connect-et",
  "manifest_repo": "ethio-connect-et/ethio-connect-manifest",
  "regexes": {
    "required_envs": "^(testing|staging|main)$",
    "target_envs": "^(testing|staging|production)$",
    "digest": "^sha256:[0-9a-f]{64}$",
    "app": "^[a-z0-9][a-z0-9-]*$"
  },
  "env_mapping": {
    "testing": "testing",
    "staging": "staging",
    "main": "production"
  },
  "idp_lookback_days": 14
}
