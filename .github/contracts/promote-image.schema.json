{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "app",
    "digest",
    "env",
    "source_repo",
    "source_ref",
    "source_commit",
    "release_id",
    "release_created_at",
    "signed_metadata",
    "attestation_bundle"
  ],
  "properties": {
    "app": {
      "type": "string"
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "env": {
      "type": "string",
      "enum": ["testing", "staging", "production"]
    },
    "source_repo": {
      "type": "string"
    },
    "source_ref": {
      "type": "string"
    },
    "source_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "release_id": {
      "type": "string"
    },
    "release_created_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "signed_metadata": {
      "type": "object",
      "required": [
        "signature_algorithm",
        "key_id",
        "cert_chain",
        "signature",
        "canonical_payload"
      ],
      "properties": {
        "signature_algorithm": { "type": "string", "minLength": 1 },
        "key_id": { "type": "string", "minLength": 1 },
        "cert_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "signature": { "type": "string", "minLength": 1 },
        "canonical_payload": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "attestation_bundle": {
      "type": "string"
    }
  }
}
