{
  "name": "@ethio-connect/public-website",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/central-hub/public-website",
  "projectType": "application",
  "tags": [
    "domain:central-hub",
    "platform:web",
    "scope:central-hub",
    "type:dashboard",
    "release:docker",
    "release:publish"
  ],
  "metadata": {
    "targetContractProfile": "app"
  },
  "targets": {
    "lint": {
      "executor": "nx:noop"
    },
    "test": {
      "executor": "nx:noop"
    },
    "build": {
      "executor": "@nx/next:build",
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/central-hub/public-website"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/central-hub/public-website"
        },
        "production": {}
      }
    },
    "deploy-metadata": {
      "dependsOn": [
        "build"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/deploy-metadata/{projectName}.json"
      ],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"application\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "prune": {
      "executor": "nx:noop"
    },
    "nx-release-publish": {
      "executor": "@nx/docker:release-publish",
      "dependsOn": [
        "docker:build"
      ]
    },
    "docker:metadata": {
      "executor": "nx:run-commands",
      "dependsOn": [
        "nx-release-publish"
      ],
      "outputs": [
        "{workspaceRoot}/dist/containers/{projectName}/image.json"
      ],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node tools/containers/write-image-manifest.mjs --project {projectName}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p apps/central-hub/public-website/tsconfig.json"
      }
    }
  }
}
