{
  "name": "@ethio-connect/central-hub-dashboard",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/central-hub/central-hub-dashboard",
  "projectType": "application",
  "tags": [
    "domain:central-hub",
    "platform:web",
    "scope:central-hub",
    "type:dashboard"
  ],
  "targets": {
    "container": {
      "dependsOn": ["build", "^build"],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/containers/{projectName}/container-metadata.json"
      ],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "docker buildx build --load --file {projectRoot}/Dockerfile --tag ${NX_DOCKER_REGISTRY:-ghcr.io}/${NX_DOCKER_REPOSITORY:-ethio-connect-et}/{projectName}:${NX_IMAGE_TAG:-local} --metadata-file dist/containers/{projectName}/container-metadata.json {projectRoot}"
      }
    },
    "container-push": {
      "dependsOn": ["container"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}/image.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/containers/{projectName} && docker buildx build --push --file {projectRoot}/Dockerfile --tag ${NX_DOCKER_REGISTRY:-ghcr.io}/${NX_DOCKER_REPOSITORY:-ethio-connect-et}/{projectName}:${NX_IMAGE_TAG:-${NX_TASK_HASH:-latest}} --metadata-file dist/containers/{projectName}/push-metadata.json {projectRoot} && DIGEST=$(python - <<'P'\nimport json\nfrom pathlib import Path\np=Path('dist/containers/{projectName}/push-metadata.json')\nj=json.loads(p.read_text()) if p.exists() else {}\nprint(j.get('containerimage.digest',''))\nP\n) && printf \"{\\n  \\\"project\\\": \\\"{projectName}\\\",\\n  \\\"image\\\": \\\"%s/%s/{projectName}:%s\\\",\\n  \\\"digest\\\": \\\"%s\\\",\\n  \\\"ref\\\": \\\"%s/%s/{projectName}@%s\\\"\\n}\\n\" \"${NX_DOCKER_REGISTRY:-ghcr.io}\" \"${NX_DOCKER_REPOSITORY:-ethio-connect-et}\" \"${NX_IMAGE_TAG:-${NX_TASK_HASH:-latest}}\" \"$DIGEST\" \"${NX_DOCKER_REGISTRY:-ghcr.io}\" \"${NX_DOCKER_REPOSITORY:-ethio-connect-et}\" \"$DIGEST\" > dist/containers/{projectName}/image.json"
      }
    },
    "lint": {
      "executor": "nx:noop"
    },
    "test": {
      "executor": "nx:noop"
    },
    "build": {
      "executor": "@nx/next:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/central-hub/central-hub-dashboard"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/central-hub/central-hub-dashboard"
        },
        "production": {}
      }
    },
    "deploy-metadata": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"application\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "nx-release-publish": {
      "executor": "@nx/docker:release-publish",
      "dependsOn": ["docker:build"],
      "cache": false,
      "options": {
        "quiet": false
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/central-hub/central-hub-dashboard/package.json",
        "{workspaceRoot}/dist/apps/central-hub/central-hub-dashboard/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/central-hub/central-hub-dashboard/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    }
  }
}
