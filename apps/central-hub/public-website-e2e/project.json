{
  "name": "@ethio-connect/public-website-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/central-hub/public-website-e2e/src",
  "tags": [
    "domain:central-hub",
    "platform:e2e",
    "scope:central-hub",
    "type:app"
  ],
  "implicitDependencies": ["@ethio-connect/public-website"],
  "metadata": {
    "targetContractProfile": "e2e"
  },
  "targets": {
    "lint": {
      "executor": "nx:noop"
    },
    "test": {
      "executor": "nx:noop"
    },
    "build": {
      "executor": "nx:noop"
    },
    "e2e": {
      "executor": "nx:noop"
    },
    "deploy-metadata": {
      "dependsOn": ["e2e"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"e2e\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:check --projects={projectName}"
      }
    },
    "format:write": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:write --projects={projectName}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p apps/central-hub/public-website-e2e/tsconfig.json"
      }
    }
  }
}
