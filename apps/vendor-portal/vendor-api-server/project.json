{
  "name": "@ethio-connect/vendor-api-server",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/vendor-portal/vendor-api-server/src",
  "projectType": "application",
  "tags": [
    "domain:vendor-portal",
    "platform:api",
    "scope:vendor-portal",
    "type:api"
  ],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": [
          "--node-env=production"
        ],
        "cwd": "apps/vendor-portal/vendor-api-server"
      },
      "configurations": {
        "development": {
          "args": [
            "--node-env=development"
          ]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": [
        "build"
      ],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/vendor-portal/vendor-api-server/package.json",
        "{workspaceRoot}/dist/apps/vendor-portal/vendor-api-server/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": [
        "build"
      ],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/vendor-portal/vendor-api-server/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": [
        "prune-lockfile",
        "copy-workspace-modules"
      ],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": [
        "build"
      ],
      "options": {
        "buildTarget": "@ethio-connect/vendor-api-server:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "@ethio-connect/vendor-api-server:build:development"
        },
        "production": {
          "buildTarget": "@ethio-connect/vendor-api-server:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    },
    "container": {
      "dependsOn": [
        "build",
        "^build"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/containers/{projectName}/container-metadata.json"
      ],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "docker buildx build --load --file {projectRoot}/Dockerfile --tag ${NX_DOCKER_REGISTRY:-ghcr.io}/${NX_DOCKER_REPOSITORY:-ethio-connect}/{projectName}:${NX_IMAGE_TAG:-local} --metadata-file dist/containers/{projectName}/container-metadata.json {projectRoot}"
      }
    },
    "container-push": {
      "dependsOn": [
        "container"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/containers/{projectName}/image.json"
      ],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/containers/{projectName} && docker buildx build --push --file {projectRoot}/Dockerfile --tag ${NX_DOCKER_REGISTRY:-ghcr.io}/${NX_DOCKER_REPOSITORY:-ethio-connect}/{projectName}:${NX_IMAGE_TAG:-${NX_TASK_HASH:-latest}} --metadata-file dist/containers/{projectName}/push-metadata.json {projectRoot} && DIGEST=$(python - <<'P'\nimport json\nfrom pathlib import Path\np=Path('dist/containers/{projectName}/push-metadata.json')\nj=json.loads(p.read_text()) if p.exists() else {}\nprint(j.get('containerimage.digest',''))\nP\n) && printf \"{\\n  \\\"project\\\": \\\"{projectName}\\\",\\n  \\\"image\\\": \\\"%s/%s/{projectName}:%s\\\",\\n  \\\"digest\\\": \\\"%s\\\",\\n  \\\"ref\\\": \\\"%s/%s/{projectName}@%s\\\"\\n}\\n\" \"${NX_DOCKER_REGISTRY:-ghcr.io}\" \"${NX_DOCKER_REPOSITORY:-ethio-connect}\" \"${NX_IMAGE_TAG:-${NX_TASK_HASH:-latest}}\" \"$DIGEST\" \"${NX_DOCKER_REGISTRY:-ghcr.io}\" \"${NX_DOCKER_REPOSITORY:-ethio-connect}\" \"$DIGEST\" > dist/containers/{projectName}/image.json"
      }
    },
    "lint": {
      "executor": "nx:noop"
    },
    "deploy-metadata": {
      "dependsOn": [
        "build"
      ],
      "executor": "nx:run-commands",
      "outputs": [
        "{workspaceRoot}/dist/deploy-metadata/{projectName}.json"
      ],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"application\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    }
  }
}
