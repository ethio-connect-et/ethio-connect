{
  "name": "@ethio-connect/vendor-portal-dashboard-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/vendor-portal/vendor-portal-dashboard-e2e/src",
  "tags": [
    "domain:vendor-portal",
    "platform:e2e",
    "scope:vendor-portal",
    "type:app"
  ],
  "implicitDependencies": ["@ethio-connect/vendor-portal-dashboard"],
  "metadata": {
    "targetContractProfile": "e2e"
  },
  "targets": {
    "lint": {
      "executor": "nx:noop"
    },
    "test": {
      "executor": "nx:noop"
    },
    "build": {
      "executor": "nx:noop"
    },
    "e2e": {
      "executor": "nx:noop"
    },
    "deploy-metadata": {
      "dependsOn": ["e2e"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"e2e\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p apps/vendor-portal/vendor-portal-dashboard-e2e/tsconfig.json"
      }
    }
  }
}
