{
  "name": "@ethio-connect/vendor-portal-dashboard",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/vendor-portal/vendor-portal-dashboard",
  "projectType": "application",
  "tags": [
    "domain:vendor-portal",
    "platform:web",
    "scope:vendor-portal",
    "type:dashboard",
    "release:docker",
    "release:publish"
  ],
  "metadata": {
    "targetContractProfile": "app"
  },
  "targets": {
    "lint": {
      "executor": "nx:noop"
    },
    "test": {
      "executor": "nx:noop"
    },
    "build": {
      "executor": "@nx/next:build",
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/vendor-portal/vendor-portal-dashboard"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/vendor-portal/vendor-portal-dashboard"
        },
        "production": {}
      }
    },
    "deploy-metadata": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"application\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "prune": {
      "executor": "nx:noop"
    },
    "docker:build": {
      "executor": "@nx/docker:build",
      "dependsOn": ["build", "prune"]
    },
    "nx-release-publish": {
      "executor": "@nx/docker:release-publish",
      "dependsOn": ["docker:build"]
    },
    "docker:metadata": {
      "executor": "nx:run-commands",
      "dependsOn": ["nx-release-publish"],
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}/image.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node tools/containers/write-image-manifest.mjs --project {projectName}"
      }
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:check --projects={projectName}"
      }
    },
    "format:write": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:write --projects={projectName}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p apps/vendor-portal/vendor-portal-dashboard/tsconfig.json"
      }
    }
  }
}
