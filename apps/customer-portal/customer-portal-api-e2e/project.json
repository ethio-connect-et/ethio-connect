{
  "name": "@ethio-connect/customer-portal-api-e2e",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": [
    "domain:customer-portal",
    "platform:e2e",
    "scope:customer-portal",
    "type:app"
  ],
  "implicitDependencies": ["@ethio-connect/customer-portal-api"],
  "metadata": {
    "targetContractProfile": "e2e"
  },
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/customer-portal/customer-portal-api-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": [
        "@ethio-connect/customer-portal-api:build",
        "@ethio-connect/customer-portal-api:serve"
      ]
    },
    "lint": {
      "executor": "nx:noop"
    },
    "test": {
      "executor": "nx:noop"
    },
    "build": {
      "executor": "nx:noop"
    },
    "deploy-metadata": {
      "dependsOn": ["e2e"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"e2e\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "nx-release-publish": {
      "options": {
        "imageName": "ghcr.io/ethio-connect-et/customer-portal-api-e2e"
      }
    }
  }
}
