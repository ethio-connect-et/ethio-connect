{
  "name": "@ethio-connect/customer-portal-api",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/customer-portal/customer-portal-api/src",
  "projectType": "application",
  "tags": [
    "domain:customer-portal",
    "platform:api",
    "scope:customer-portal",
    "type:api",
    "release:docker",
    "release:publish"
  ],
  "metadata": {
    "targetContractProfile": "app"
  },
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "webpack-cli build",
        "args": ["--node-env=production"],
        "cwd": "apps/customer-portal/customer-portal-api"
      },
      "configurations": {
        "development": {
          "args": ["--node-env=development"]
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/dist/apps/customer-portal/customer-portal-api/package.json",
        "{workspaceRoot}/dist/apps/customer-portal/customer-portal-api/pnpm-lock.yaml"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/dist/apps/customer-portal/customer-portal-api/workspace_modules"
      ],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "@ethio-connect/customer-portal-api:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "@ethio-connect/customer-portal-api:build:development"
        },
        "production": {
          "buildTarget": "@ethio-connect/customer-portal-api:build:production"
        }
      }
    },
    "test": {
      "options": {
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "nx:noop"
    },
    "deploy-metadata": {
      "dependsOn": ["build"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/deploy-metadata/{projectName}.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"{projectName}\",\\n  \"root\": \"{projectRoot}\",\\n  \"type\": \"application\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/{projectName}.json"
      }
    },
    "docker:build": {
      "executor": "@nx/docker:build",
      "dependsOn": ["build", "prune"]
    },
    "nx-release-publish": {
      "executor": "@nx/docker:release-publish",
      "dependsOn": ["docker:build"]
    },
    "docker:metadata": {
      "executor": "nx:run-commands",
      "dependsOn": ["nx-release-publish"],
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}/image.json"],
      "options": {
        "cwd": "{workspaceRoot}",
        "command": "node tools/containers/write-image-manifest.mjs --project {projectName}"
      }
    }
  }
}
