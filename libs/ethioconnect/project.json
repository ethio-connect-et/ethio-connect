{
  "name": "@ethio-connect/ethioconnect",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ethioconnect/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    },
    "publish": false
  },
  "tags": [
    "scope:shared",
    "type:util",
    "domain:shared",
    "platform:cross",
    "release:publish"
  ],
  "metadata": {
    "targetContractProfile": "library",
    "targetContract": {
      "allowedForbiddenTargets": {
        "nx-release-publish": "Required by scripts/validate-target-contract.mjs for library profile; kept as noop to satisfy release contract parity."
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/ethioconnect",
        "main": "libs/ethioconnect/src/index.ts",
        "tsConfig": "libs/ethioconnect/tsconfig.lib.json",
        "assets": ["libs/ethioconnect/*.md"],
        "generatePackageJson": true
      }
    },
    "package": {
      "executor": "nx:noop",
      "dependsOn": ["build"]
    },
    "nx-release-publish": {
      "executor": "nx:noop",
      "dependsOn": ["package"]
    }
  }
}
