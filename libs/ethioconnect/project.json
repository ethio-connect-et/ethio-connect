{
  "name": "@ethio-connect-et/ethioconnect",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/ethioconnect/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    },
    "publish": true
  },
  "tags": [
    "scope:shared",
    "type:util",
    "domain:shared",
    "platform:cross",
    "release:npm",
    "type:contracts"
  ],
  "metadata": {
    "targetContractProfile": "library",
    "targetContract": {
      "allowedForbiddenTargets": {
        "nx-release-publish": "Required by scripts/validate-target-contract.mjs for library profile; kept as noop to satisfy release contract parity."
      }
    }
  },
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p libs/ethioconnect/tsconfig.json"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/ethioconnect",
        "main": "libs/ethioconnect/src/index.ts",
        "tsConfig": "libs/ethioconnect/tsconfig.lib.json",
        "assets": [
          "libs/ethioconnect/*.md"
        ],
        "generatePackageJson": true
      }
    },
    "nx-release-publish": {
      "executor": "@nx/js:release-publish",
      "dependsOn": [
        "build"
      ],
      "options": {
        "registry": "https://npm.pkg.github.com/",
        "tag": "latest"
      }
    }
  }
}
