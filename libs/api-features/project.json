{
  "name": "@ethio-connect/api-features",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api-features/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:feature", "domain:shared", "platform:api"],
  "// targets": "to see all targets run: nx show project @ethio-connect/api-features --web",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/api-features",
        "main": "libs/api-features/src/index.ts",
        "tsConfig": "libs/api-features/tsconfig.lib.json",
        "assets": ["libs/api-features/*.md"],
        "generatePackageJson": true
      }
    },
    "package": {
      "executor": "nx:noop",
      "dependsOn": ["build"]
    },
    "nx-release-publish": {
      "options": {
        "packageRoot": "dist/{projectRoot}"
      }
    }
  },
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    }
  }
}
