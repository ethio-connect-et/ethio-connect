{
  "name": "@ethio-connect/api-features",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api-features/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    },
    "publish": false
  },
  "tags": [
    "scope:shared",
    "type:feature",
    "domain:shared",
    "platform:api",
    "release:publish"
  ],
  "metadata": {
    "targetContractProfile": "library",
    "targetContract": {
      "allowedForbiddenTargets": {
        "nx-release-publish": "Required by scripts/validate-target-contract.mjs for library profile; kept as noop to satisfy release contract parity."
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/api-features",
        "main": "libs/api-features/src/index.ts",
        "tsConfig": "libs/api-features/tsconfig.lib.json",
        "assets": [
          "libs/api-features/*.md"
        ],
        "generatePackageJson": true
      }
    },
    "package": {
      "executor": "nx:noop",
      "dependsOn": [
        "build"
      ]
    },
    "nx-release-publish": {
      "executor": "nx:noop",
      "dependsOn": [
        "package"
      ]
    },
    "format:check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:check --projects={projectName}"
      }
    },
    "format:write": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm nx format:write --projects={projectName}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p libs/api-features/tsconfig.json"
      }
    }
  }
}
