{
  "name": "@ethio-connect/frontend-features",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/frontend-features/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": [
        "dist/{projectRoot}"
      ],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    },
    "publish": false
  },
  "tags": [
    "scope:shared",
    "type:feature",
    "domain:shared",
    "platform:web",
    "release:publish"
  ],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": [
        "{options.outputPath}"
      ],
      "options": {
        "outputPath": "dist/libs/frontend-features",
        "main": "libs/frontend-features/src/index.ts",
        "tsConfig": "libs/frontend-features/tsconfig.lib.json",
        "assets": [
          "libs/frontend-features/*.md"
        ],
        "generatePackageJson": true
      }
    },
    "package": {
      "executor": "nx:noop",
      "dependsOn": [
        "build"
      ]
    },
    "nx-release-publish": {
      "executor": "nx:noop"
    }
  },
  "metadata": {
    "targetContractProfile": "library"
  }
}
