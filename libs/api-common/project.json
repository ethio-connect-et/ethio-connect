{
  "name": "@ethio-connect/api-common",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/api-common/src",
  "projectType": "library",
  "release": {
    "version": {
      "manifestRootsToUpdate": ["dist/{projectRoot}"],
      "currentVersionResolver": "git-tag",
      "fallbackCurrentVersionResolver": "disk"
    },
    "publish": false
  },
  "tags": [
    "scope:shared",
    "type:util",
    "domain:shared",
    "platform:api",
    "release:publish"
  ],
  "metadata": {
    "targetContractProfile": "library",
    "targetContract": {
      "allowedForbiddenTargets": {
        "nx-release-publish": "Required by scripts/validate-target-contract.mjs for library profile; kept as noop to satisfy release contract parity."
      }
    }
  },
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/api-common",
        "main": "libs/api-common/src/index.ts",
        "tsConfig": "libs/api-common/tsconfig.lib.json",
        "assets": ["libs/api-common/*.md"],
        "generatePackageJson": true
      }
    },
    "package": {
      "executor": "nx:noop",
      "dependsOn": ["build"]
    },
    "nx-release-publish": {
      "executor": "nx:noop",
      "dependsOn": ["package"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc --noEmit -p libs/api-common/tsconfig.json"
      }
    }
  }
}
