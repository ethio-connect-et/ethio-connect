      "dependsOn": ["container"],
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/containers/{projectName}/image.json"],
      "options": {
        "cwd": "",
        "command": "mkdir -p dist/containers/@ethio-connect/central-hub-api && docker buildx build --push --file apps/central-hub/central-hub-api/Dockerfile --tag ${NX_DOCKER_REGISTRY:-ghcr.io}/${NX_DOCKER_REPOSITORY:-ethio-connect-et}/@ethio-connect/central-hub-api:${NX_IMAGE_TAG:-${NX_TASK_HASH:-latest}} --metadata-file dist/containers/@ethio-connect/central-hub-api/push-metadata.json apps/central-hub/central-hub-api && DIGEST=$(python - <<'P'\nimport json\nfrom pathlib import Path\np=Path('dist/containers/@ethio-connect/central-hub-api/push-metadata.json')\nj=json.loads(p.read_text()) if p.exists() else {}\nprint(j.get('containerimage.digest',''))\nP\n) && printf \"{\\n  \\\"project\\\": \\\"@ethio-connect/central-hub-api\\\",\\n  \\\"image\\\": \\\"%s/%s/@ethio-connect/central-hub-api:%s\\\",\\n  \\\"digest\\\": \\\"%s\\\",\\n  \\\"ref\\\": \\\"%s/%s/@ethio-connect/central-hub-api@%s\\\"\\n}\\n\" \"${NX_DOCKER_REGISTRY:-ghcr.io}\" \"${NX_DOCKER_REPOSITORY:-ethio-connect-et}\" \"${NX_IMAGE_TAG:-${NX_TASK_HASH:-latest}}\" \"$DIGEST\" \"${NX_DOCKER_REGISTRY:-ghcr.io}\" \"${NX_DOCKER_REPOSITORY:-ethio-connect-et}\" \"$DIGEST\" > dist/containers/@ethio-connect/central-hub-api/image.json"
      },
