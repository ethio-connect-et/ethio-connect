      "options": {
        "cwd": "",
        "command": "docker buildx build --load --file apps/central-hub/central-hub-api/Dockerfile --tag ${NX_DOCKER_REGISTRY:-ghcr.io}/${NX_DOCKER_REPOSITORY:-ethio-connect-et}/@ethio-connect/central-hub-api:${NX_IMAGE_TAG:-local} --metadata-file dist/containers/@ethio-connect/central-hub-api/container-metadata.json apps/central-hub/central-hub-api"
      },
      "configurations": {},
