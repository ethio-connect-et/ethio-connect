        "command": "mkdir -p dist/deploy-metadata && printf '{\\n  \"project\": \"@ethio-connect/central-hub-api\",\\n  \"root\": \"apps/central-hub/central-hub-api\",\\n  \"type\": \"application\",\\n  \"timestamp\": \"'\"$(date -u +%Y-%m-%dT%H:%M:%SZ)\"'\"\\n}\\n' > dist/deploy-metadata/@ethio-connect/central-hub-api.json"
      },
      "configurations": {},
      "parallelism": true
